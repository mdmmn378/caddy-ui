# Default template config for the full-stack compose (docker-compose.full.yml).
#
# This file is the STARTING POINT only. Caddy starts with `--resume`, so:
#   - On the very first `docker compose up` (no autosave yet) this Caddyfile is
#     loaded and immediately autosaved as JSON to /config/caddy/autosave.json.
#   - On every restart after that, Caddy resumes from that autosave (the live
#     config you built in the UI) and this Caddyfile is IGNORED.
# /config is a named volume, so the autosave — and therefore everything you
# create in the UI — survives `docker compose down` / restarts / upgrades.
#
# The global `admin` directive exposes the Admin API so the UI container can
# reach it over the compose network. 0.0.0.0 is fine here because the port is
# NOT published to the host in docker-compose.full.yml — only other services on
# the internal network can reach it. Do NOT expose :2019 publicly in production.
#
# When the admin endpoint is bound to a non-loopback address, Caddy enforces an
# allow-list of request origins (DNS-rebinding protection). The UI reaches Caddy
# at http://caddy:2019, so that Host must be listed under `origins`.
{
	admin 0.0.0.0:2019 {
		origins caddy:2019 localhost:2019 127.0.0.1:2019
	}
}

# Start with no sites — add them from the Caddy UI. This block is just a
# friendly placeholder so `caddy run` has something to serve on :80.
#
# Cloudflare DNS-01: add a token from the UI's "TLS & DNS" page. To keep the
# secret out of the saved config, pass CLOUDFLARE_API_TOKEN to the caddy service
# (see docker-compose.full.yml) and reference it as {env.CLOUDFLARE_API_TOKEN}.
:80 {
	respond "Caddy is running. Configure routes from Caddy UI." 200
}
